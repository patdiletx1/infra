# Ctrlz — Environment Variables
# Copy to /opt/ctrlz/.env and fill in real values

# Agora RTC
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# Gemini AI Vision
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Telegram Bot (same bot as Hermes)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=7704641454
CTRLZ_TELEGRAM_POLLING=false

# OpenAI (fallback)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Server
PORT=5000
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=https://ctrlz.app

# Stream settings
STREAM_NO_VIEWER_TIMEOUT_MS=30000
SESSION_MAX_AGE_MS=600000

# Device registration
DEVICE_REGISTRATION_TOKEN_TTL_MS=300000
DEVICE_REGISTRATION_SECRET=your-device-secret

# Lemon Squeezy payments
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_VARIANT_ID_BASIC=12345
LEMONSQUEEZY_VARIANT_ID_PRO=12346
LEMONSQUEEZY_VARIANT_ID_ENTERPRISE=12347

PUBLIC_VIEWER_ORIGIN=https://ctrlz.app
VITE_API_URL=
