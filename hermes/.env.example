# Hermes Agent — Environment Variables
# Copy to ~/.hermes/.env and fill in real values

# LLM Provider (DeepSeek)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# OpenRouter (fallback, free tier)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=8673190503:AAF-your-bot-token
TELEGRAM_ALLOWED_USERS=7704641454

# ElevenLabs TTS (optional)
ELEVENLABS_API_KEY=sk-your-elevenlabs-key
