# HTTPS for ctrlz.app
ctrlz.app {
	root * /var/www/ctrlz/viewer

	header /phone/sw.js Service-Worker-Allowed /phone/

	header /phone/index.html {
		Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
		Pragma "no-cache"
		Expires "0"
	}
	header /index.html {
		Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
		Pragma "no-cache"
		Expires "0"
	}

	@phoneNoSlash {
		path /phone
		not path /phone/*
	}
	redir @phoneNoSlash /phone/ 301

	@appNoSlash {
		path /app
		not path /app/*
	}
	redir @appNoSlash /app/ 301

	handle /api/* {
		reverse_proxy localhost:5000
	}

	handle_path /app/* {
		reverse_proxy localhost:5002
	}

	handle_path /lib/* {
		root * /var/www/ctrlz/lib
		file_server
	}

	handle_path /phone/* {
		root * /var/www/ctrlz/phone
		file_server
	}

	handle_path /live/* {
		try_files {path} /index.html
		file_server
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}

