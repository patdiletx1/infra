# HTTP for IP access
http://91.99.157.147 {
	handle /api/* {
		reverse_proxy localhost:3000
	}
	handle /health {
		reverse_proxy localhost:3000
	}
	handle {
		reverse_proxy localhost:3001 {
			header_up Host 91.99.157.147
		}
	}
}

