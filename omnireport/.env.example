# OmniReport — Environment Variables
# Copy to /opt/OmniReport/.env and fill in real values

# Server
PORT=3000
NODE_ENV=production
CORS_ORIGINS=https://quotedme.app

# Database
DATABASE_URL=postgresql://quotedme:quotedme_password@postgres:5432/quotedme
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
CLERK_SECRET_KEY=sk_live_your-clerk-secret-key
CLERK_WEBHOOK_SECRET=whsec_your-clerk-webhook-secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your-clerk-publishable-key

# AI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
NVIDIA_API_KEY=your-nvidia-api-key
GOOGLE_API_KEY=your-google-api-key

# S3 / Object Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=quotedme-reports
AWS_REGION=fsn1
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_FORCE_PATH_STYLE=false

# Payments (Lemon Squeezy)
BYPASS_LEMONSQUEEZY=false
NEXT_PUBLIC_BYPASS_LEMONSQUEEZY=false
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_VARIANT_ID_STARTER=12345
NEXT_PUBLIC_VARIANT_ID_PRO=12346
NEXT_PUBLIC_VARIANT_ID_BUSINESS=12347
NEXT_PUBLIC_VARIANT_ID_ENTERPRISE=12348
NEXT_PUBLIC_VARIANT_ID_CREDITS_10=12349
NEXT_PUBLIC_VARIANT_ID_CREDITS_50=12350
NEXT_PUBLIC_VARIANT_ID_CREDITS_100=12351

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://quotedme.app/api/telegram-webhook

# WhatsApp
WHATSAPP_ENABLED=false
